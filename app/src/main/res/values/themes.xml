<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.HabitSeed" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/habitseed_forest_green</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/habitseed_forest_green</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/seed_logo_splash_foreground</item>
        <item name="windowSplashScreenAnimationDuration">200</item>
        <item name="postSplashScreenTheme">@style/Theme.HabitSeed</item>
    </style>
</resources>
